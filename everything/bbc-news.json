articles: [{"source": {"id": "bbc-news", "name": "BBC News"}, "author": "https://www.facebook.com/bbcnews", "title": "The Papers: End to pay freeze and Facebook 'in the dock'", "description": "Many of the papers focus on Wednesday's Budget, including plans to scrap a public sector pay freeze.", "url": "https://www.bbc.co.uk/news/blogs-the-papers-59045671", "urlToImage": "https://ichef.bbci.co.uk/news/1024/branded_news/A78B/production/_121219824_indexmailandguardian2610.png", "publishedAt": "2021-10-25T22:23:08Z", "content": "Watch the latest episode\r\nThe BBC News Channels press review every evening at 22:40 weekdays, 22:30 and 23:30 weekends and via the BBC iPlayer"}, {"source": {"id": "bbc-news", "name": "BBC News"}, "author": null, "title": "2021/10/25 22:00 GMT", "description": "The latest five minute news bulletin from BBC World Service.", "url": "https://www.bbc.co.uk/programmes/w172xzjsyzr57gs", "urlToImage": "https://ichef.bbci.co.uk/images/ic/1200x675/p060dh18.jpg", "publishedAt": "2021-10-25T22:06:00Z", "content": "The latest five minute news bulletin from BBC World Service."}, {"source": {"id": "bbc-news", "name": "BBC News"}, "author": null, "title": "Transfer rumours: Salah, Solskjaer, Nakamba, Gerrard, Chalobah, Koeman, Van de Beek", "description": "Salah's new Liverpool deal demands, Zidane not interested in Manchester United job, Newcastle target Nakamba and Van de Beek, plus more.", "url": "https://www.bbc.co.uk/sport/59041669", "urlToImage": "https://ichef.bbci.co.uk/live-experience/cps/624/cpsprodpb/A277/production/_121219514_gossip.png", "publishedAt": "2021-10-25T21:52:41Z", "content": "Liverpool and Egypt forward Mohamed Salah, 29, wants a \u00a3500,000-a-week contract to stay with the Reds. (Football Insider)external-link\r\nOle Gunnar Solskjaer is fighting to save his job as Manchester \u2026 [+1896 chars]"}, {"source": {"id": "bbc-news", "name": "BBC News"}, "author": "https://www.facebook.com/bbcnews", "title": "COP26 volunteers proud to help showcase Glasgow and its people", "description": "A 1,000-strong team of volunteers have taken to the streets of Glasgow to play their part in COP26.", "url": "https://www.bbc.co.uk/news/uk-scotland-glasgow-west-59037295", "urlToImage": "https://ichef.bbci.co.uk/news/1024/branded_news/3175/production/_121216621_cyntbia.jpg", "publishedAt": "2021-10-25T21:51:12Z", "content": "Media caption, Cynthia Tjipuka says she is \"honoured and humbled\" to have been chosen as a COP26 volunteer\r\nA 1,000-strong team of volunteers have taken to the streets of Glasgow to play their part i\u2026 [+2277 chars]"}, {"source": {"id": "bbc-news", "name": "BBC News"}, "author": "https://www.facebook.com/bbcnews", "title": "Coal tips: Areas of Wales with most higher-risk sites revealed", "description": "One county in Wales has 75 tips which pose a potential safety threat, new figures show.", "url": "https://www.bbc.co.uk/news/uk-wales-politics-59041863", "urlToImage": "https://ichef.bbci.co.uk/news/1024/branded_news/10A7B/production/_120891286_gettyimages-1207095762.jpg", "publishedAt": "2021-10-25T21:50:26Z", "content": "Image source, Getty Images\r\nImage caption, A landslide at a tip in Tylorstown prompted new work to identify Wales' disused coal tips\r\nRhondda Cynon Taf has the largest number of higher-risk coal tips\u2026 [+4383 chars]"}, {"source": {"id": "bbc-news", "name": "BBC News"}, "author": "https://www.facebook.com/bbcnews", "title": "Covid: Figures show vaccine booster gap in high-risk groups", "description": "More than 100,000 Scots are waiting for a booster despite receiving their second dose more than six months ago.", "url": "https://www.bbc.co.uk/news/uk-scotland-58995601", "urlToImage": "https://ichef.bbci.co.uk/news/1024/branded_news/9E18/production/_121127404_gettyimages-1344952312.jpg", "publishedAt": "2021-10-25T21:50:19Z", "content": "Image source, Getty Images\r\nImage caption, Boosters should be given at least six months after the second dose\r\nA signifi